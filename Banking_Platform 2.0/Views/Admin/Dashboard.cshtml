@{
    ViewBag.Title = "Dashboard";
    Layout = "~/Views/Shared/_Layout.cshtml"; // adjust if needed
}

<link href="~/css/site.css" rel="stylesheet" />

<style>
    .toggle-btn {
        cursor: pointer;
    }
    .sidebar {
        top: 3.85rem;
    }
    .dropdown-item {
        color: #333;
        height: 3rem;
        display: flex;
        align-items: center;
    }
    .dropdown-item:hover {
        background-color: white;
        color: #007bff;
    }
</style>

<div class="container-xxl position-relative bg-white d-flex p-0">
    <!-- Sidebar -->
    <div class="sidebar pe-4 pb-3 position-sticky col-3">
        <nav class="navbar">
            <div class="navbar-nav w-100">
                <a asp-controller="Admin" asp-action="home" class="nav-item nav-link active">
                    <i class="fa fa-tachometer-alt me-2"></i>Dashboard
                </a>

                <!-- Transaction Dropdown -->
                <div class="nav-item dropdown">
                    <a class="nav-link toggle-btn" id="drdn-toggle-1">
                        <i class="bi bi-repeat me-2"></i>Transaction
                    </a>
                    <div class="drdn-item-1 bg-transparent border-0 d-none">
                        <a asp-controller="Admin" asp-action="deposit-money" class="dropdown-item ajax-link" data-target="tgt">Deposit</a>
                        <a asp-controller="Admin" asp-action="Withdraw" class="dropdown-item ajax-link" data-target="tgt">Withdraw</a>
                        <a asp-controller="Admin" asp-action="Transfer" class="dropdown-item ajax-link" data-target="tgt">Transfer</a>
                    </div>
                </div>

                <!-- Account Dropdown -->
                <div class="nav-item dropdown">
                    <a class="nav-link toggle-btn" id="drdn-toggle-2">
                        <i class="far fa-file-alt me-2"></i>Account
                    </a>
                    <div class="drdn-item-2 bg-transparent border-0 d-none">
                        <a asp-controller="Admin" asp-action="New_Account" class="dropdown-item ajax-link" data-target="tgt">New Account</a>
                        <a asp-controller="Admin" asp-action="modify-account" class="dropdown-item ajax-link" data-target="tgt">Modify</a>
                        <a asp-controller="Admin" asp-action="Balance_Inquary" class="dropdown-item ajax-link" data-target="tgt">Balance Inquiry</a>
                    </div>
                </div>

                <!-- Profile Dropdown -->
                <div class="nav-item dropdown">
                    <a class="nav-link toggle-btn" id="drdn-toggle-3">
                        <i class="bi bi-person-circle me-2"></i>Profile
                    </a>
                    <div class="drdn-item-3 bg-transparent border-0 d-none">
                        <a asp-controller="Admin" asp-action="LeaveApplication" class="dropdown-item ajax-link" data-target="tgt">Leave Application</a>
                        <a asp-controller="Login" asp-action="Logout" class="dropdown-item">
                            Logout <i class="bi bi-box-arrow-right px-2"></i>
                        </a>
                    </div>
                </div>

            </div>
        </nav>
    </div>

    <!-- Main Content -->
    <div class="w-100">
        <div id="tgt" class="w-100">
            <div class="container-fluid pt-4 px-4">
                <h3 class="text-center">
                    <span class="text-success">You've got this. </span>
                    <span class="text-primary">Let's do great work today!</span>
                </h3>
            </div>
            <div class="container-fluid pt-4 px-4">
                <div class="row g-4">
                    <div class="col-sm-12 col-md-6 col-xl-6">
                        <div class="h-100 bg-light rounded p-4">
                            <div class="d-flex align-items-center justify-content-between mb-2">
                                <h6 class="mb-0">Messages</h6>
                                <a href="">Show All</a>
                            </div>
                            <div class="d-flex align-items-center border-bottom py-3">
                                <div class="w-100 ms-3">
                                    <div class="d-flex w-100 justify-content-between">
                                        <h6 class="mb-0">Jhon Doe</h6>
                                        <small>15 minutes ago</small>
                                    </div>
                                    <span>Short message goes here...</span>
                                </div>
                            </div>
                        </div>
                    </div>
                </div>
            </div>
        </div>
    </div>
</div>

@section Scripts {
    <script>
        $(document).ready(function () {

            // AJAX partial load replacing jquery.unobtrusive-ajax
            $(document).on('click', '.ajax-link', function (e) {
                e.preventDefault();
                var url = $(this).attr('href');
                var targetId = $(this).data('target');
                $('#' + targetId).load(url);
            });

            function toggleDropdown(triggerSelector, contentSelector) {
                var $content = $(contentSelector);
                var $trigger = $(triggerSelector);

                if ($content.hasClass('d-none')) {
                    $content.removeClass('d-none').hide().slideDown('slow');
                    $trigger.addClass('active');
                } else {
                    $content.slideUp('slow', function () {
                        $content.addClass('d-none');
                    });
                    $trigger.removeClass('active');
                }
            }

            $('#drdn-toggle-1').on('click', function () {
                toggleDropdown('#drdn-toggle-1', '.drdn-item-1');
            });

            $('#drdn-toggle-2').on('click', function () {
                toggleDropdown('#drdn-toggle-2', '.drdn-item-2');
            });

            $('#drdn-toggle-3').on('click', function () {
                toggleDropdown('#drdn-toggle-3', '.drdn-item-3');
            });

        });
    </script>
}