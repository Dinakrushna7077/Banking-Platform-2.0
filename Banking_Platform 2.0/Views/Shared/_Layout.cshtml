@{
    int role = Context.Session.GetInt32("Role") != null ? Context.Session.GetInt32("Role").Value : 0;
    string rolename = "";
    if (role == 1)
    {
        rolename = "Manager";
    }
    else if (role == 2)
    {
        rolename = "Admin";
    }
    else
    {
        rolename = "User";
    }
}
<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>@ViewData["Title"] - Urban Banking</title>
    <link rel="icon" type="image/png" href="@Url.Content("~/Assets/icon3.png")" />
    <link rel="stylesheet" href="~/lib/bootstrap/dist/css/bootstrap.min.css" />
    <link href="~/css/site.css" rel="stylesheet" />
    <link href="~/css/urbanbank.css" rel="stylesheet" />
    @* <link rel="stylesheet" href="~/css/style.css" asp-append-version="true" /> *@
    <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.7.2/css/all.min.css" integrity="sha512-Evv84Mr4kqVGRNSgIGL/F/aIDqQb7xQ2vcrdIwxfjThSH8CSR7PBEakCr51Ck+w+/U6swU2Im1vVX0SVk9ABhg==" crossorigin="anonymous" referrerpolicy="no-referrer" />

</head>
<body>
    <header>
        <nav class="navbar navbar-expand-lg navbar-light bank-body fixed-top bank-navbar" id="mainNavbar">
            <div class="container-fluid">
                <i class="fa-solid fa-building-columns fs-3 text-dark nav-link px-1"></i>
                <a class="navbar-brand text-dark fw-bold" asp-area="" asp-controller="Home" asp-action="Index">URBAN BANK</a>
                <button class="navbar-toggler" type="button" data-bs-toggle="collapse" data-bs-target="#navbarContent" aria-controls="navbarContent" aria-expanded="false" aria-label="Toggle navigation">
                    <span class="navbar-toggler-icon"></span>
                </button>
                <div class="collapse navbar-collapse" id="navbarContent">
                    <!-- Left side navs -->
                    <ul class="navbar-nav me-auto mb-2 mb-lg-0">
                        <li class="nav-item">
                            <a class="nav-link text-dark" asp-area="" asp-controller="Home" asp-action="Index">Home</a>
                        </li>
                        <li class="nav-item">
                            <a class="nav-link text-dark" href="@Url.Action("Index", "Home")#about">About</a>
                        </li>

                        <li class="nav-item">
                            <a class="nav-link text-dark" href="@Url.Action("Index", "Home")#contact">Contact</a>
                        </li>
                        
                    </ul>
                    <!-- Right side navs -->
                    <ul class="navbar-nav ms-auto mb-2 mb-lg-0">
                        @if (role == 0)
                        {
                            <li class="nav-item d-flex">
                                <a asp-area="" asp-controller="User" asp-action="Register" class="nav-link text-dark">Register</a>
                                @* @Html.ActionLink("User Register", "UserResister", "Admin", new { area = "" }, new { @class = "nav-link text-dark" }) *@
                            </li>
                            <li class="nav-item">
                                <a asp-area="" asp-controller="Login" asp-action="Login" class="nav-link text-black">Login</a>
                                @* @Html.ActionLink("Login", "Login", "Login", new { area = "" }, new { @class = "nav-link text-dark" }) *@
                            </li>
                        }
                        else
                        {
                            <li class="nav-item">
                                <a class="nav-link text-dark fw-bolder"><i class="bi bi-person-fill"></i>@rolename</a>
                            </li>
                        }
                    </ul>
                </div>
            </div>
        </nav>
    </header>
    <div class="container-fluid">
        <main role="main" class=" mt-4">
            @RenderBody()
        </main>
    </div>
    <hr />
    <footer class="text-center text-lg-start text-white bg-color">
        <div class="container p-4 pb-0">
            <section class="">
                <div class="row">
                    <div class="col-md-3 col-lg-3 col-xl-3 mx-auto mt-3">
                        <h6 class="text-uppercase mb-4 font-weight-bold">
                            Urban Banking
                        </h6>
                        <p>
                            A secure and seamless digital banking platform designed to simplify financial management and enhance user experience.
                        </p>
                    </div>
                    <hr class="w-100 clearfix d-md-none" />
                    <div class="col-md-2 col-lg-2 col-xl-2 mx-auto mt-3">
                        <h6 class="text-uppercase mb-4 font-weight-bold">Essential Navigation Links</h6>
                        <p>
                            <a class="text-white nav-link">About Us</a>
                        </p>
                        <p>
                            <a class="text-white nav-link">Contact Us</a>
                        </p>
                        <p>
                            <a class="text-white nav-link">Careers</a>
                        </p>
                        <p>
                            <a class="text-white nav-link">Help Center / Support</a>
                        </p>
                    </div>
                    <hr class="w-100 clearfix d-md-none" />
                    <div class="col-md-3 col-lg-2 col-xl-2 mx-auto mt-3">
                        <h6 class="text-uppercase mb-4 font-weight-bold">
                            Legal & Compliance
                        </h6>
                        <p>
                            <a class="text-white nav-link">Security</a>
                        </p>
                        <p>
                            <a class="text-white nav-link">Privacy Policy</a>
                        </p>
                        <p>
                            <a class="text-white nav-link">Terms & Conditions</a>
                        </p>
                        <p>
                            <a class="text-white nav-link">Cookies Policy</a>
                        </p>
                    </div>
                    <hr class="w-100 clearfix d-md-none" />
                    <div class="col-md-4 col-lg-3 col-xl-3 mx-auto mt-3">
                        <h6 class="text-uppercase mb-4 font-weight-bold"> Services / Products</h6>
                        <p>
                            <a class="text-white nav-link">Personal/Business Banking</a>
                        </p>
                        <p>
                            <a class="text-white nav-link">Loans & Mortgages</a>
                        </p>
                        <p>
                            <a class="text-white nav-link">Credit Cards</a>
                        </p>
                        <p>
                            <a class="text-white nav-link">Investment Services</a>
                        </p>
                    </div>
                </div>
            </section>
            <hr class="my-3">
            <section class="p-3 pt-0">
                <div class="row d-flex align-items-center">
                    <div class="col-md-7 col-lg-8 text-center text-md-start">
                        <div class="p-3">
                            &copy; @DateTime.Now.Year
                            @Html.ActionLink("- FBZ Application", "Index", "Home", new { area = "" }, new { @class = "nav-link text-white d-inline" })
                        </div>
                    </div>
                    <div class="col-md-5 col-lg-4 ml-lg-0 text-center text-md-end">
                        <a href="https://www.facebook.com/dinakrushana.mohanta.7" class="btn btn-outline-light btn-floating m-1" role="button">
                            <i class="fab fa-facebook-f"></i>
                        </a>
                        <a href="https://x.com/mohanta5673" class="btn btn-outline-light btn-floating m-1" role="button">
                            <i class="fab fa-twitter"></i>
                        </a>
                        <a href="https://www.instagram.com/official_dina_adc/" class="btn btn-outline-light btn-floating m-1" role="button">
                            <i class="fab fa-instagram"></i>
                        </a>
                    </div>
                </div>
            </section>
        </div>
    </footer>
    <!-- Footer -->
    <script src="~/lib/jquery/dist/jquery.min.js"></script>
    <script src="~/lib/bootstrap/dist/js/bootstrap.bundle.min.js"></script>
    <script src="~/js/site.js" asp-append-version="true"></script>
    @await RenderSectionAsync("Scripts", required: false)
    <script>
                $(document).ready(function () {
            const $navbar = $('#mainNavbar');

            $(window).on('scroll', function () {
                const currentScroll = $(this).scrollTop();

                if (currentScroll === 0) {
                    $navbar.removeClass('scrolled-up');
                } else {
                    $navbar.addClass('scrolled-up');
                }
            });
        });
    </script>
    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.10.5/font/bootstrap-icons.css">

</body>
</html>
