                            <div class="row">
                                <div class="col-md-6">
                                    <div class="inputbox mt-2">
                                        <div class="position-relative">
                                            <select asp-for="BranchCode"
                                                    asp-items="@(ViewBag.Branch as List<SelectListItem>)"
                                                    class="form-control" id="branchSelect">
                                                <option value="">--- Select Branch ---</option>
                                            </select>
                                            <i class="bi bi-bank"></i>
                                        </div>
                                        <span asp-validation-for="BranchCode" class="text-danger small"></span>
                                    </div>
                                </div>
                                <div class="col-md-6">
                                    <div class="inputbox mt-2">
                                        <div class="position-relative">
                                            <input asp-for="IFSCCode" class="form-control"
                                                   placeholder="IFSC Code (auto-filled)"
                                                   readonly id="ifscCode" />
                                            <i class="bi bi-upc"></i>
                                        </div>
                                    </div>
                                </div>
                            </div>



                            <div class="row">
                                <div class="col-md-6">
                                    <div class="inputbox mt-2">
                                        <div class="position-relative">
                                            <input asp-for="Name" class="form-control"
                                                   placeholder="Full Name" required />
                                            <i class="bi bi-person"></i>
                                        </div>
                                        <span asp-validation-for="Name" class="text-danger small"></span>
                                    </div>
                                </div>
                                <div class="col-md-6">
                                    <div class="mt-2 mb-3">
                                        <p class="section-label mb-2">Gender</p>
                                        <div class="radio-group">
                                            <input asp-for="Gender" type="radio" value="Male" id="male" />
                                            <label for="male">Male</label>

                                            <input asp-for="Gender" type="radio" value="Female" id="female" />
                                            <label for="female">Female</label>

                                            <input asp-for="Gender" type="radio" value="Other" id="other" />
                                            <label for="other">Other</label>
                                        </div>
                                    </div>
                                </div>
                            </div>
                            <div class="row">
                                <div class="col-md-6">
                                    <div class="inputbox">
                                        <div class="position-relative">
                                            <input asp-for="FatherName" class="form-control"
                                                   placeholder="Father Name" required />
                                            <i class="bi bi-person-fill"></i>
                                        </div>
                                        <span asp-validation-for="FatherName" class="text-danger small"></span>
                                    </div>
                                </div>
                                <div class="col-md-6">
                                    <div class="inputbox">
                                        <div class="position-relative">
                                            <input asp-for="MotherName" class="form-control"
                                                   placeholder="Mother Name" required />
                                            <i class="bi bi-person-fill"></i>
                                        </div>
                                        <span asp-validation-for="MotherName" class="text-danger small"></span>
                                    </div>
                                </div>
                            </div>


                            <div class="row">
                                <div class="col-md-6">
                                    <div class="inputbox mt-2">
                                        <div class="position-relative">
                                            <input asp-for="MobileNumber" class="form-control"
                                                   placeholder="Mobile Number" required />
                                            <i class="bi bi-phone"></i>
                                        </div>
                                        <span asp-validation-for="MobileNumber" class="text-danger small"></span>
                                    </div>
                                </div>
                                <div class="col-md-6">
                                    <div class="inputbox mt-2">
                                        <div class="position-relative">
                                            <input asp-for="Email" type="email" class="form-control"
                                                   placeholder="Email Address" required />
                                            <i class="bi bi-envelope"></i>
                                        </div>
                                        <span asp-validation-for="Email" class="text-danger small"></span>
                                    </div>
                                </div>
                            </div>
                            <div class="row">
                                <div class="col-md-6">
                                    <div class="inputbox">
                                        <div class="position-relative">
                                            <input asp-for="AdharNumber" class="form-control"
                                                   placeholder="Aadhar Number" required />
                                            <i class="bi bi-credit-card"></i>
                                        </div>
                                        <span asp-validation-for="AdharNumber" class="text-danger small"></span>
                                    </div>
                                </div>
                                <div class="col-md-6">
                                    <div class="inputbox">
                                        <div class="position-relative">
                                            <input asp-for="PanNumber" class="form-control"
                                                   placeholder="PAN Number" required />
                                            <i class="bi bi-card-text"></i>
                                        </div>
                                        <span asp-validation-for="PanNumber" class="text-danger small"></span>
                                    </div>
                                </div>
                            </div>

                            <div class="row">
