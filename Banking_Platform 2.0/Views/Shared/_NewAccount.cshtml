                        </div>

                        <div class="summary-box">
                            <p class="section-label mb-3">Account Summary</p>
                            <div class="summary-row">
                                <span class="s-label">Full Name</span>
                                <span class="s-value" id="sumName">—</span>
                            </div>
                            <div class="summary-row">
                                <span class="s-label">Date of Birth</span>
                                <span class="s-value" id="sumDob">—</span>
                            </div>
                            <div class="summary-row">
                                <span class="s-label">Mobile</span>
                                <span class="s-value" id="sumMobile">—</span>
                            </div>
                            <div class="summary-row">
                                <span class="s-label">Email</span>
                                <span class="s-value" id="sumEmail" style="font-size:12px;">—</span>
                            </div>
                            <div class="summary-row">
                                <span class="s-label">Branch</span>
                                <span class="s-value" id="sumBranch">—</span>
                            </div>
                            <div class="summary-row">
                                <span class="s-label">IFSC</span>
                                <span class="s-value" id="sumIfsc">—</span>
                            </div>
                            <div class="summary-row">
                                <span class="s-label">Account Type</span>
                                <span class="s-value" id="sumType">—</span>
                            </div>
                            <div class="summary-row">
                                <span class="s-label">Gender</span>
                                <span class="s-value" id="sumGender">—</span>
                            </div>
                            <div class="summary-row">
                                <span class="s-label">Initial Deposit</span>
                                <span class="s-value text-success" id="sumDeposit">₹ —</span>
                            </div>
                        </div>

                        <div class="alert-info-custom p-3">
                            <i class="bi bi-info-circle me-1"></i>
                            <strong>Note:</strong> Fill in all the fields. The summary on the right updates as you type.
                            Minimum initial deposit is <strong>₹500</strong>.
                        </div>

                    </div>
                </div>

            </form>
        </div>
    </div>
</div>

@* @section Scripts {
    @await Html.PartialAsync("_ValidationScriptsPartial") *@

<script>
    $(document).ready(function () {

        // ── Live Summary Update ───────────────────────────────────────────
        function updateSummary() {
            var name    = $('input[name="Name"]').val()          || '—';
            var mobile  = $('input[name="MobileNumber"]').val()  || '—';
            var email   = $('input[name="Email"]').val()         || '—';
            var ifsc    = $('#ifscCode').val()                   || '—';
            var type    = $('input[name="AccountType"]:checked').val() || '—';
            var gender  = $('input[name="Gender"]:checked').val()      || '—';
            var deposit = parseFloat($('#initialDeposit').val()) || 0;
            var branch  = $('#branchSelect option:selected').text();
            var dob = $('input[name="DateOfBirth"]').val() || '—';
            if (branch === '--- Select Branch ---') branch = '—';


            // Summary box
            $('#sumName').text(name);
            $('#sumDob').text(dob);
            $('#sumMobile').text(mobile);
            $('#sumEmail').text(email);
            $('#sumBranch').text(branch);
            $('#sumIfsc').text(ifsc);
            $('#sumType').text(type);
            $('#sumGender').text(gender);
            $('#sumDeposit').text(deposit > 0 ? '₹ ' + deposit.toLocaleString('en-IN') : '₹ —');

            // Preview card
            $('#previewName').text(name !== '—' ? name : '— —');
            $('#previewType').text(type);
            $('#previewBranch').text(branch);


        }


        // ── Bind all inputs for live update ──────────────────────────────
        $(document).on('input change', 'input, select', updateSummary);

        // ── Auto-fill IFSC on branch change ──────────────────────────────
        $('#branchSelect').on('change', function () {
            var branchId = $(this).val();
            //alert(branchId);
            if (branchId) {
                $.ajax({
                    url: '@Url.Action("get-ifsc", "Admin")',
                    type: 'GET',
                    data: { branchId: branchId },
                    success: function (res) {
                        $('#ifscCode').val(res.ifsc);
                        $('#sumIfsc').text(res.ifsc);
                        updateSummary();
                    },
                    error: function () {
                        alert('Error retrieving IFSC code.');
                    }
                });
            } else {
                $('#ifscCode').val('');
                updateSummary();
            }
        });

        // ── AJAX Form Submit ──────────────────────────────────────────────
       $('#newAccountForm').on('submit', function (e) {
            e.preventDefault();

            $.ajax({
            url: '@Url.Action("create-account", "Admin")',
            type: 'POST',
            data: $(this).serialize(),
            success: function (response) {
                $('#tgt').html(response);
            }
         });
     });

    });
</script>
@* } *@